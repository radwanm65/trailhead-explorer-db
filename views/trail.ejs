<%- include('partials/header') %>

<article class="trail-detail">
  <h1><%= trail.name %></h1>
  <span class="badge badge-<%= trail.difficulty.toLowerCase() %>"><%= trail.difficulty %></span>
  <p><%= trail.distance_km %> km</p>
  <p><%= trail.description %></p>

  <!-- notes comes from a SEPARATE table (trail_notes), joined by
       trail_id - a trail can have zero, one, or many notes. -->
  <% if (notes.length > 0) { %>
    <% notes.forEach(note => { %>
      <div class="note-box">
        <strong>Note:</strong> <%= note.note %>
      </div>
    <% }) %>
  <% } %>

  <p><a href="/">&larr; Back to all trails</a></p>
</article>

<%- include('partials/footer') %>
